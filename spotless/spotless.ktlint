[{*.kt}]
ktlint_code_style = intellij_idea
insert_final_newline = true
max_line_length = 120

ij_kotlin_imports_layout = dev.toby0207.astralgenerators.**,|,net.**,|,*,|,java.**,javax.**,kotlin.**,|,^
ij_kotlin_packages_to_use_import_on_demand = java.util.*,dev.toby0207.astralgenerators.**
ktlint_standard_class-naming = true
ktlint_standard_function-naming = disabled
ktlint_standard_no-wildcard-imports = disabled
